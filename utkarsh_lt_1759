class Solution {
public:
    int countHomogenous(string s) {
        int MOD=1e9+7;
        long long count=1;
        long long  ans=0;
        for(int i=0;i<s.length()-1;i++){
            if(s[i]==s[i+1]){
                count++;
            }else{
                ans+=(count*(count+1))/2;
                count=1;
            }
            }
            ans+=(count*(count+1))/2;
            return ans%MOD;
    }
};
